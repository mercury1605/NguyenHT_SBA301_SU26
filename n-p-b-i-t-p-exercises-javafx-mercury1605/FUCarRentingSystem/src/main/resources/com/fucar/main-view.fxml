<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fucar.controller.MainController"
            stylesheets="@style.css"
            prefWidth="1024" prefHeight="680">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="Hệ thống">
                    <MenuItem text="Đăng nhập lại"/>
                    <MenuItem text="Đổi mật khẩu"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Thoát" onAction="#handleExit"/>
                </Menu>
                <Menu text="Quản lý">
                    <MenuItem text="Quản lý xe" onAction="#navCars"/>
                    <MenuItem text="Quản lý khách hàng" onAction="#navCustomers"/>
                    <MenuItem text="Giao dịch thuê xe" onAction="#navRental"/>
                </Menu>
                <Menu text="Báo cáo">
                    <MenuItem text="Báo cáo theo kỳ" onAction="#navReport"/>
                    <MenuItem text="Xuất Excel"/>
                </Menu>
                <Menu text="Trợ giúp">
                    <MenuItem text="Hướng dẫn sử dụng"/>
                    <MenuItem text="Về chúng tôi"/>
                </Menu>
            </MenuBar>

            <ToolBar>
                <Button fx:id="btnCars" text="🚗 Quản lý xe" onAction="#navCars"/>
                <Button fx:id="btnCustomers" text="👤 Quản lý KH" onAction="#navCustomers"/>
                <Button fx:id="btnRental" text="📋 Giao dịch" onAction="#navRental"/>
                <Button fx:id="btnReport" text="📊 Báo cáo" onAction="#navReport"/>
                <Separator/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblUser" text="Xin chào, Admin" style="-fx-font-weight:bold;-fx-padding:0 10 0 0;"/>
            </ToolBar>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="200" style="-fx-background-color:#1A237E;">
            <Label text="MENU CHÍNH" maxWidth="Infinity" alignment="CENTER"
                   style="-fx-font-weight:bold;-fx-text-fill:white; -fx-padding:12;-fx-font-size:13px;"/>
            <Accordion fx:id="accordion">
                <panes>
                    <TitledPane text="🗂 Quản lý">
                        <VBox spacing="4" style="-fx-padding:4 5;">
                            <Button text="🚗 Quản lý xe" maxWidth="Infinity" onAction="#navCars"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                            <Button text="👤 Quản lý KH" maxWidth="Infinity" onAction="#navCustomers"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                            <Button text="📋 Giao dịch" maxWidth="Infinity" onAction="#navRental"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                        </VBox>
                    </TitledPane>
                    <TitledPane text="📊 Báo cáo">
                        <VBox spacing="4" style="-fx-padding:4 5;">
                            <Button text="📅 Báo cáo kỳ" maxWidth="Infinity" onAction="#navReport"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                            <Button text="📈 Thống kê tổng" maxWidth="Infinity"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                        </VBox>
                    </TitledPane>
                    <TitledPane text="⚙ Cài đặt">
                        <VBox spacing="4" style="-fx-padding:4 5;">
                            <Button text="🔑 Đổi mật khẩu" maxWidth="Infinity"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                            <Button text="ℹ Thông tin hệ thống" maxWidth="Infinity"
                                    style="-fx-alignment: BASELINE_LEFT; -fx-cursor: hand;"/>
                        </VBox>
                    </TitledPane>
                </panes>
            </Accordion>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <VBox alignment="CENTER" spacing="16">
                <Label text="Chào mừng đến với FUCarRentingSystem"
                       style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1F4E79;"/>
                <Label text="Chọn chức năng từ menu bên trái hoặc thanh công cụ"
                       style="-fx-font-size:14px;-fx-text-fill:#757575;"/>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color:#E3F2FD;-fx-padding:4 10;" alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblStatus" text="Sẵn sàng" style="-fx-text-fill:#555;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDateTime" style="-fx-text-fill:#555;"/>
        </HBox>
    </bottom>
</BorderPane>